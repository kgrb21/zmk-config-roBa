#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/input/input-event-codes.h>

/ {
    chosen {
        /* Pinkeybdの配線方式と行列定義を優先して指定します */
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /* Pinkeybdの特殊な配線（チャーリープレックス）の定義 [cite: 3, 44] */
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-charlieplex";
        wakeup-source; [cite: 3]

        /* 割り込みピン */
        interrupt-gpios = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>; [cite: 3, 45]

        /* 使用する6つのピン [cite: 4, 46] */
        gpios
            = <&xiao_d 1 GPIO_ACTIVE_HIGH>
            , <&xiao_d 2 GPIO_ACTIVE_HIGH>
            , <&xiao_d 3 GPIO_ACTIVE_HIGH>
            , <&xiao_d 6 GPIO_ACTIVE_HIGH>
            , <&xiao_d 7 GPIO_ACTIVE_HIGH>
            , <&xiao_d 8 GPIO_ACTIVE_HIGH> [cite: 47]
            ;
    };

    /* Pinkeybd専用の行列定義（10行x6列） [cite: 5, 48] */
    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        rows = <10>; [cite: 5, 49]
        columns = <6>; [cite: 49]
        map = <
            RC(1,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC( 7,0) RC( 6,1) RC( 6,2) RC( 6,3) RC(6,4)
            RC(2,0) RC(2,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC( 8,0) RC( 8,1) RC( 7,2) RC( 7,3) RC(7,4)
            RC(3,0) RC(3,1) RC(3,2) RC(2,3) RC(2,4) RC(2,5)  RC( 9,0) RC( 9,1) RC( 9,2) RC( 8,3) RC(8,4)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(10,0) RC(10,1) RC(10,2) RC(10,3) RC(9,4) 
        >;
    };

    /* 左側のエンコーダー定義 [cite: 8] */
    left_encoder: encoder_left {
        compatible = "alps,ec11";
        /* Pinkeybdの元データに合わせ D4 と D5 を使用  */
        a-gpios = <&xiao_d 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; 
        b-gpios = <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; 
        steps = <24>; 
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder>; [cite: 11]
        triggers-per-rotation = <12>; [cite: 11]
    };
};
